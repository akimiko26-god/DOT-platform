# Локально без Docker — SQLite (по умолчанию):
DATABASE_URL=sqlite:///./dot_local.db
# С Docker / PostgreSQL:
# DATABASE_URL=postgresql://dot:dot_secret@localhost:5432/dot_platform
SECRET_KEY=change-me-to-long-random-string
FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000
# Бесплатный AI для CRM (https://aistudio.google.com/apikey):
GEMINI_API_KEY=
# Модель (по умолчанию gemini-2.5-flash — стабильнее, чем 2.0-flash):
GEMINI_MODEL=gemini-2.5-flash
SEED_DEMO=true
